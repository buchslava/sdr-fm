{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDR FM",
  "version": "0.1.0",
  "identifier": "com.sdrfm.app",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/sdr-fm/browser"
  },
  "app": {
    "windows": [
      {
        "title": "SDR FM",
        "width": 480,
        "height": 360
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright (c) 2026 Viacheslav Chub (vyacheslav.chub@gmail.com)",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "macOS": {
      "bundleName": "SDR FM"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
